{
    "name": "mrpotensial/ezdoc",
    "description": "Document engine dengan template versioning, RBAC, audit log, dan QR verify. Framework-agnostic PHP library.",
    "type": "library",
    "keywords": ["document", "template", "signature", "verify", "audit", "qr", "rbac"],
    "license": "MIT",
    "authors": [
        {
            "name": "mrpotensial",
            "email": "qaedi.dev@gmail.com"
        }
    ],
    "require": {
        "php": ">=7.4",
        "ext-mysqli": "*",
        "ext-json": "*",
        "ext-mbstring": "*"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.0 || ^10.0 || ^11.0",
        "phpstan/phpstan": "^1.10",
        "symfony/polyfill-php80": "^1.28",
        "symfony/polyfill-php81": "^1.28"
    },
    "suggest": {
        "symfony/polyfill-php80": "Recommended untuk PHP 7.4 runtime — battle-tested polyfill (str_starts_with, str_ends_with, str_contains, get_debug_type). Kalau tidak install, lib/polyfill.php akan handle fallback minimal."
    },
    "autoload": {
        "psr-4": {
            "Ezdoc\\": "src/"
        },
        "files": [
            "lib/polyfill.php",
            "lib/uuid.php",
            "lib/responses.php",
            "lib/role_provider.php",
            "lib/authorization.php",
            "lib/schema.php",
            "lib/migrations.php",
            "lib/audit.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Ezdoc\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit",
        "stan": "phpstan analyse src --level=6",
        "check-compat": "vendor/bin/phpstan analyse src --level=1 --configuration=phpstan-php74.neon"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
